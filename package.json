{
  "name": "azeta-homes",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:worker": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "lint:worker": "tsc --project tsconfig.worker.json --noEmit",
    "test": "vitest",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration",
    "db:migrate:local": "wrangler d1 execute azeta-homes-db --local --file=worker/db/schema.sql",
    "db:seed:local": "wrangler d1 execute azeta-homes-db --local --file=worker/db/seed.sql",
    "db:migrate": "wrangler d1 execute azeta-homes-db --remote --file=worker/db/schema.sql",
    "db:seed": "wrangler d1 execute azeta-homes-db --remote --file=worker/db/seed.sql"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "hono": "^4.7.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-calendly": "^4.4.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
