# Cloudflare Pages / Workers Assets headers
# Applied to every response. Edit with care: a too-strict Content-Security-Policy
# can silently break the Calendly modal, Google Fonts, framer-motion inline styles,
# or the testimonial images served from imgur.com. CSP is intentionally NOT set here;
# see comment below for a recommended policy to test before enabling.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  X-DNS-Prefetch-Control: off

# --- Recommended CSP (test in a Cloudflare preview deployment before enabling on production) ---
# Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.calendly.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https://i.imgur.com https://*.calendly.com; connect-src 'self' https://calendly.com https://*.calendly.com; frame-src https://calendly.com https://*.calendly.com; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'

# Long-cache hashed static assets
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Long-cache the hero video
/videohere_opt.mp4
  Cache-Control: public, max-age=31536000, immutable
