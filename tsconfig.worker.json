{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "outDir": "./dist-worker",
    "rootDir": ".",
    "types": ["@cloudflare/workers-types"]
  },
  "include": ["worker/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
